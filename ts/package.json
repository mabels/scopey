{
  "name": "@adviser/scopey",
  "version": "0.0.0",
  "description": "better try/catch/finally handling",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/scopey.d.ts",
      "import": "./src/scopey.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "build": "pnpm run build:tsgo ; pnpm run build:js ",
    "build:tsgo": "tsgo",
    "build:js": "rm -rf dist/pkg ; mkdir -p dist/pkg; cp -pr ./dist/ts/* dist/pkg",
    "test": "pnpm run test:js",
    "test:js": "vitest --run",
    "pubdir": "pnpm run build; rm -rf pubdir ; mkdir -p pubdir; cp -pr ../.gitignore package.json ../README.md ../LICENSE pubdir/; cd dist ; cp -pr . ../pubdir/",
    "presmoke": "npx cement preparePubdir",
    "smoke": "bash ./smoke/it.sh",
    "deno:publish": "pnpm run pubdir; cd dist/pubdir ; pnpm exec deno publish --allow-dirty --unstable-sloppy-imports --quiet",
    "lint": "eslint . --ext .ts",
    "format": "prettier ."
  },
  "keywords": [],
  "author": "Meno Abels <meno.abels@adviser.com>",
  "license": "AFL-2.0",
  "bugs": {
    "url": "https://github.com/mabels/scopey/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mabels/scopey"
  },
  "homepage": "https://github.com/mabels/scopey#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@typescript/native-preview": "7.0.0-dev.20260305.1",
    "cmd-ts": "^0.15.0",
    "deno": "^2.7.4",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "zx": "^8.8.5"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@adviser/cement": "^0.5.33"
  }
}
