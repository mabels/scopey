{
  "name": "@adviser/scopey",
  "version": "0.0.0",
  "description": "better try/catch/finally handling",
  "main": "src/scopey.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/ts/index.d.ts",
      "import": "./dist/ts/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "build": "pnpm run build:js",
    "build:js": "tsgo",
    "test": "pnpm run test:js",
    "test:js": "vitest --run",
    "pubdir": "pnpm run build; rm -rf pubdir ; mkdir -p pubdir; cp -pr ../.gitignore package.json ../README.md ../LICENSE pubdir/; cd dist ; cp -pr . ../pubdir/",
    "presmoke": "pnpm run pubdir ; cd pubdir ; pnpm pack",
    "smoke": "cd smoke; rm -f package.json; pnpm init ; pnpm install -f ../pubdir/adviser-scopey-*.tgz; npx tsx ./smoke.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier ."
  },
  "keywords": [],
  "author": "Meno Abels <meno.abels@adviser.com>",
  "license": "AFL-2.0",
  "bugs": {
    "url": "https://github.com/mabels/scopey/issues"
  },
  "homepage": "https://github.com/mabels/scopey#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@typescript/native-preview": "7.0.0-dev.20260305.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@adviser/cement": "^0.5.33"
  }
}
